# ===========================================
# Flat Rate Imports - Producción (Hostinger)
# ===========================================
# Copia este archivo como .env en el servidor
# y rellena los valores según tu configuración.

APP_NAME=FlatRateImports
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tudominio.com
APP_TIMEZONE=America/Guayaquil
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=sync

# Hostinger: smtp.hostinger.com, puerto 465, ssl
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@tudominio.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@tudominio.com
MAIL_FROM_NAME="${APP_NAME}"

TRACKINGMORE_API_KEY=

WHATSAPP_NUMBER=
WHATSAPP_MESSAGE="Hola, me interesa conocer más sobre sus servicios de importación."

RED_MOVIL_NUMBER=
RED_MOVIL_MESSAGE="Hola, me interesa conocer más sobre sus servicios de importación."

CHAT_PROVIDER=tidio
TIDIO_PUBLIC_KEY=
CRISP_WEBSITE_ID=

FILESYSTEM_DISK=local

SEO_DEFAULT_TITLE="Flat Rate Imports - Importa desde USA a Ecuador"
SEO_DEFAULT_DESCRIPTION="Cotiza tu envío desde USA a Ecuador. Casillero postal, importaciones, tracking de paquetes."
GOOGLE_ANALYTICS_ID=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

ECOMMERCE_STORE_URL=https://flatrateimports.store

WEBHOOK_LEADS_URL=
WEBHOOK_QUOTES_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
