APP_NAME=FlatRateImports
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Producción: u199005242_flat_rate | Local: laravel o flat_rate
DB_DATABASE=u199005242_flat_rate
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

# Mail (necesario para "Enviar por email" en el cotizador)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Tracking (TrackingMore API)
TRACKINGMORE_API_KEY=

# WhatsApp
WHATSAPP_NUMBER=
WHATSAPP_MESSAGE="Hola, me interesa conocer más sobre sus servicios de importación."

# Red Móvil
RED_MOVIL_NUMBER=
RED_MOVIL_MESSAGE="Hola, me interesa conocer más sobre sus servicios de importación."

# Chat Widget (Tidio o Crisp)
CHAT_PROVIDER=tidio
TIDIO_PUBLIC_KEY=
CRISP_WEBSITE_ID=

FILESYSTEM_DISK=local

# SEO y Analítica (Fase 8)
SEO_DEFAULT_TITLE="Flat Rate Imports - Importa desde USA a Ecuador"
SEO_DEFAULT_DESCRIPTION="Cotiza tu envío desde USA a Ecuador. Casillero postal, importaciones, tracking de paquetes."
GOOGLE_ANALYTICS_ID=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Ecommerce (Fase 10)
ECOMMERCE_STORE_URL=https://flatrateimports.store

# Webhooks automatización (Fase 12 - n8n, Zapier)
WEBHOOK_LEADS_URL=
WEBHOOK_QUOTES_URL=

# Google OAuth (inicio de sesión con cuenta Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
